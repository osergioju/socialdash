generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[]

  @@map("users")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

// ─── Agency client management ─────────────────────────────────────────────────

model Client {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  logoUrl            String?
  website            String?
  notes              String?
  createdById        String
  createdBy          User                 @relation(fields: [createdById], references: [id])
  connections        PlatformConnection[]
  instagramMetrics   InstagramMetric[]
  linkedinMetrics    LinkedinMetric[]
  ga4Metrics         Ga4Metric[]
  cities             City[]
  themes             Theme[]
  ga4Pages           Ga4Page[]
  ga4Origins         Ga4Origin[]
  linkedinIndustries LinkedinIndustry[]
  linkedinRoles      LinkedinRole[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@map("clients")
}

model PlatformConnection {
  id           String           @id @default(cuid())
  clientId     String
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform     OAuthPlatform
  status       ConnectionStatus @default(PENDING)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  accountId    String?
  accountName  String?
  accountEmail String?
  metadata     String? // JSON: instagramBusinessAccountId, pageId, propertyId, organizationUrn
  lastSyncAt   DateTime?
  connectedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([clientId, platform])
  @@map("platform_connections")
}

enum OAuthPlatform {
  META
  GOOGLE_ANALYTICS
  LINKEDIN
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

// ─── Metrics (all scoped by clientId) ─────────────────────────────────────────

model InstagramMetric {
  id                     String   @id @default(cuid())
  clientId               String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month                  String // e.g. "2025-04"
  monthLabel             String // e.g. "Abril/25"
  seguidores             Int
  novosSeguidores        Int
  alcanceOrganico        Int
  visualizacoes          Int
  interacoes             Int
  visitasPerfil          Int
  postagensTotal         Int
  reelsQtd               Int
  reelsAlcance           Int
  reelsInteracoes        Int
  storiesQtd             Int
  storiesViews           Int
  curtidasPosts          Int
  comentariosPosts       Int
  salvamentosPosts       Int
  compartilhamentosPosts Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([clientId, month])
  @@map("instagram_metrics")
}

model LinkedinMetric {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month           String
  monthLabel      String
  seguidores      Int
  novosSeguidores Int
  alcance         Int
  impressoes      Int
  engajamento     Int
  cliques         Int
  reacoes         Int
  postagens       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, month])
  @@map("linkedin_metrics")
}

model Ga4Metric {
  id                    String   @id @default(cuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month                 String
  monthLabel            String
  usuariosAtivos        Int
  novosUsuarios         Int
  usuariosTotais        Int
  sessoes               Int
  sessoesEngajadas      Int
  taxaEngajamento       Float
  tempoMedioEngajamento Int
  tempoMedioSessao      Int?
  viewsPorSessao        Float
  numEventos            Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([clientId, month])
  @@map("ga4_metrics")
}

model City {
  id       String       @id @default(cuid())
  clientId String
  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  platform Platform
  metrics  CityMetric[]

  @@unique([clientId, name, platform])
  @@map("cities")
}

model CityMetric {
  id         String   @id @default(cuid())
  cityId     String
  city       City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  month      String
  seguidores Int
  createdAt  DateTime @default(now())

  @@unique([cityId, month])
  @@map("city_metrics")
}

enum Platform {
  INSTAGRAM
  LINKEDIN
}

model Theme {
  id        String        @id @default(cuid())
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tema      String
  icon      String
  platform  Platform
  metrics   ThemeMetric[]
  createdAt DateTime      @default(now())

  @@unique([clientId, platform, tema])
  @@map("themes")
}

model ThemeMetric {
  id                String   @id @default(cuid())
  themeId           String
  theme             Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  month             String
  curtidas          Int?
  comentarios       Int?
  compartilhamentos Int?
  alcanceMedio      Int?
  engajamento       Int?
  cliques           Int?
  createdAt         DateTime @default(now())

  @@unique([themeId, month])
  @@map("theme_metrics")
}

model Ga4Page {
  id       String          @id @default(cuid())
  clientId String
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pagina   String
  label    String
  metrics  Ga4PageMetric[]

  @@unique([clientId, pagina])
  @@map("ga4_pages")
}

model Ga4PageMetric {
  id         String  @id @default(cuid())
  pageId     String
  page       Ga4Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  month      String
  views      Int?
  tempoMedio Int?

  @@unique([pageId, month])
  @@map("ga4_page_metrics")
}

model Ga4Origin {
  id       String            @id @default(cuid())
  clientId String
  client   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fonte    String
  metrics  Ga4OriginMetric[]

  @@unique([clientId, fonte])
  @@map("ga4_origins")
}

model Ga4OriginMetric {
  id         String    @id @default(cuid())
  originId   String
  origin     Ga4Origin @relation(fields: [originId], references: [id], onDelete: Cascade)
  month      String
  sessoes    Int?
  taxaEng    Float?
  tempoMedio Int?

  @@unique([originId, month])
  @@map("ga4_origin_metrics")
}

model LinkedinIndustry {
  id       String                   @id @default(cuid())
  clientId String
  client   Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nome     String
  metrics  LinkedinIndustryMetric[]

  @@unique([clientId, nome])
  @@map("linkedin_industries")
}

model LinkedinIndustryMetric {
  id         String           @id @default(cuid())
  industryId String
  industry   LinkedinIndustry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  month      String
  seguidores Int
  createdAt  DateTime         @default(now())

  @@unique([industryId, month])
  @@map("linkedin_industry_metrics")
}

model LinkedinRole {
  id       String               @id @default(cuid())
  clientId String
  client   Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nome     String
  metrics  LinkedinRoleMetric[]

  @@unique([clientId, nome])
  @@map("linkedin_roles")
}

model LinkedinRoleMetric {
  id         String       @id @default(cuid())
  roleId     String
  role       LinkedinRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  month      String
  seguidores Int
  createdAt  DateTime     @default(now())

  @@unique([roleId, month])
  @@map("linkedin_role_metrics")
}
