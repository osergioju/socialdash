generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String
  password    String
  role        Role             @default(VIEWER)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  clients     Client[]
  memberships TeamMembership[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

model Team {
  id        String           @id @default(cuid())
  name      String
  slug      String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  members   TeamMembership[]
  clients   Client[]

  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

// ─── Agency client management ─────────────────────────────────────────────────

model Client {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  logoUrl            String?
  website            String?
  notes              String?
  createdById        String
  createdBy          User                 @relation(fields: [createdById], references: [id])
  teamId             String?
  team               Team?                @relation(fields: [teamId], references: [id])
  connections        PlatformConnection[]
  clientUsers        ClientUser[]
  instagramMetrics   InstagramMetric[]
  linkedinMetrics    LinkedinMetric[]
  ga4Metrics         Ga4Metric[]
  cities             City[]
  themes             Theme[]
  ga4Pages           Ga4Page[]
  ga4Origins         Ga4Origin[]
  linkedinIndustries LinkedinIndustry[]
  linkedinRoles      LinkedinRole[]
  aiInsights         AiInsight[]
  instagramPosts     InstagramPost[]
  campaigns          Campaign[]
  monitorings        Monitoring[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([createdById])
  @@index([teamId])
  @@map("clients")
}

model PlatformConnection {
  id           String           @id @default(cuid())
  clientId     String
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform     OAuthPlatform
  status       ConnectionStatus @default(PENDING)
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  accountId    String?
  accountName  String?
  accountEmail String?
  metadata     String? // JSON: instagramBusinessAccountId, pageId, propertyId, organizationUrn
  lastSyncAt   DateTime?
  connectedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([clientId, platform])
  @@index([status])
  @@map("platform_connections")
}

// ─── Client-facing logins ─────────────────────────────────────────────────────

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, email])
  @@map("client_users")
}

enum OAuthPlatform {
  META
  GOOGLE_ANALYTICS
  LINKEDIN
}

enum ConnectionStatus {
  PENDING
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

// ─── Metrics (all scoped by clientId) ─────────────────────────────────────────

model InstagramMetric {
  id                     String   @id @default(cuid())
  clientId               String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month                  String // e.g. "2025-04"
  monthLabel             String // e.g. "Abril/25"
  seguidores             Int
  novosSeguidores        Int
  alcanceOrganico        Int
  visualizacoes          Int
  interacoes             Int
  visitasPerfil          Int
  postagensTotal         Int
  reelsQtd               Int
  reelsAlcance           Int
  reelsInteracoes        Int
  storiesQtd             Int
  storiesViews           Int
  curtidasPosts          Int
  comentariosPosts       Int
  salvamentosPosts       Int
  compartilhamentosPosts Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([clientId, month])
  @@map("instagram_metrics")
}

model LinkedinMetric {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month           String
  monthLabel      String
  seguidores      Int
  novosSeguidores Int
  alcance         Int
  impressoes      Int
  engajamento     Int
  cliques         Int
  reacoes         Int
  postagens       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, month])
  @@map("linkedin_metrics")
}

model Ga4Metric {
  id                    String   @id @default(cuid())
  clientId              String
  client                Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month                 String
  monthLabel            String
  usuariosAtivos        Int
  novosUsuarios         Int
  usuariosTotais        Int
  sessoes               Int
  sessoesEngajadas      Int
  taxaEngajamento       Float
  tempoMedioEngajamento Int
  tempoMedioSessao      Int?
  viewsPorSessao        Float
  numEventos            Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([clientId, month])
  @@map("ga4_metrics")
}

model City {
  id       String       @id @default(cuid())
  clientId String
  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  platform Platform
  metrics  CityMetric[]

  @@unique([clientId, name, platform])
  @@map("cities")
}

model CityMetric {
  id         String   @id @default(cuid())
  cityId     String
  city       City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  month      String
  seguidores Int
  createdAt  DateTime @default(now())

  @@unique([cityId, month])
  @@map("city_metrics")
}

enum Platform {
  INSTAGRAM
  LINKEDIN
}

model Theme {
  id        String          @id @default(cuid())
  clientId  String
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tema      String
  icon      String
  platform  Platform
  metrics   ThemeMetric[]
  posts     InstagramPost[]
  createdAt DateTime        @default(now())

  @@unique([clientId, platform, tema])
  @@map("themes")
}

model ThemeMetric {
  id                String   @id @default(cuid())
  themeId           String
  theme             Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  month             String
  curtidas          Int?
  comentarios       Int?
  compartilhamentos Int?
  alcanceMedio      Int?
  engajamento       Int?
  cliques           Int?
  createdAt         DateTime @default(now())

  @@unique([themeId, month])
  @@map("theme_metrics")
}

model Ga4Page {
  id       String          @id @default(cuid())
  clientId String
  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pagina   String
  label    String
  metrics  Ga4PageMetric[]

  @@unique([clientId, pagina])
  @@map("ga4_pages")
}

model Ga4PageMetric {
  id         String  @id @default(cuid())
  pageId     String
  page       Ga4Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  month      String
  views      Int?
  tempoMedio Int?

  @@unique([pageId, month])
  @@map("ga4_page_metrics")
}

model Ga4Origin {
  id       String            @id @default(cuid())
  clientId String
  client   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fonte    String
  metrics  Ga4OriginMetric[]

  @@unique([clientId, fonte])
  @@map("ga4_origins")
}

model Ga4OriginMetric {
  id         String    @id @default(cuid())
  originId   String
  origin     Ga4Origin @relation(fields: [originId], references: [id], onDelete: Cascade)
  month      String
  sessoes    Int?
  taxaEng    Float?
  tempoMedio Int?

  @@unique([originId, month])
  @@map("ga4_origin_metrics")
}

model LinkedinIndustry {
  id       String                   @id @default(cuid())
  clientId String
  client   Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nome     String
  metrics  LinkedinIndustryMetric[]

  @@unique([clientId, nome])
  @@map("linkedin_industries")
}

model LinkedinIndustryMetric {
  id         String           @id @default(cuid())
  industryId String
  industry   LinkedinIndustry @relation(fields: [industryId], references: [id], onDelete: Cascade)
  month      String
  seguidores Int
  createdAt  DateTime         @default(now())

  @@unique([industryId, month])
  @@map("linkedin_industry_metrics")
}

model LinkedinRole {
  id       String               @id @default(cuid())
  clientId String
  client   Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nome     String
  metrics  LinkedinRoleMetric[]

  @@unique([clientId, nome])
  @@map("linkedin_roles")
}

model LinkedinRoleMetric {
  id         String       @id @default(cuid())
  roleId     String
  role       LinkedinRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  month      String
  seguidores Int
  createdAt  DateTime     @default(now())

  @@unique([roleId, month])
  @@map("linkedin_role_metrics")
}

model InstagramPost {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  postId    String
  caption   String?
  mediaType String
  timestamp DateTime
  month     String
  likes     Int      @default(0)
  comments  Int      @default(0)
  reach     Int      @default(0)
  saved     Int      @default(0)
  shares    Int      @default(0)
  plays     Int      @default(0)
  themeId   String?
  theme     Theme?   @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, postId])
  @@index([clientId])
  @@map("instagram_posts")
}

model AiInsight {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month          String // "2025-04"
  canalPrincipal Json
  insights       Json
  generatedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, month])
  @@map("ai_insights")
}

// ─── Módulo Campanhas ─────────────────────────────────────────────────────────

model Campaign {
  id          String             @id @default(cuid())
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      CampaignStatus     @default(PLANNING)
  color       String? // hex, ex: "#0D9488"
  imageUrl    String?
  objective   String?
  tags        String[]           @default([])
  responsible String?
  notes       String?
  channels    CampaignChannel[]
  posts       CampaignPost[]
  pages       CampaignPage[]
  aiReports   CampaignAiReport[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([clientId])
  @@map("campaigns")
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  ENDED
}

// Canal como String (não enum) para permitir novos canais (EMAIL, TIKTOK, X…)
// sem alteração estrutural. Valores atuais: INSTAGRAM | LINKEDIN | WEBSITE.
model CampaignChannel {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel    String
  createdAt  DateTime @default(now())

  @@unique([campaignId, channel])
  @@map("campaign_channels")
}

model CampaignPost {
  id           String    @id @default(cuid())
  campaignId   String
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  channel      String // INSTAGRAM | LINKEDIN | futuros
  externalId   String // id do conteúdo na plataforma
  caption      String?
  mediaType    String?
  thumbnailUrl String?
  permalink    String?
  publishedAt  DateTime?
  metrics      Json? // { reach, likes, comments, shares, saved, plays, impressions, reactions, clicks }
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([campaignId, channel, externalId])
  @@index([campaignId])
  @@map("campaign_posts")
}

model CampaignPage {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pagePath   String
  label      String?
  createdAt  DateTime @default(now())

  @@unique([campaignId, pagePath])
  @@map("campaign_pages")
}

model CampaignAiReport {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  report      Json
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([campaignId])
  @@map("campaign_ai_reports")
}

// ─── Módulo Social Listening ──────────────────────────────────────────────────

model Monitoring {
  id              String               @id @default(cuid())
  clientId        String
  client          Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  brand           String
  language        String               @default("pt")
  country         String               @default("BR")
  startDate       DateTime             @default(now())
  status          MonitoringStatus     @default(ACTIVE)
  lastCollectedAt DateTime?
  keywords        MonitoringKeyword[]
  sources         ListeningSource[]
  mentions        Mention[]
  aiReports       ListeningAiReport[]
  alertRules      ListeningAlertRule[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([clientId])
  @@map("monitorings")
}

enum MonitoringStatus {
  ACTIVE
  PAUSED
}

model MonitoringKeyword {
  id           String      @id @default(cuid())
  monitoringId String
  monitoring   Monitoring  @relation(fields: [monitoringId], references: [id], onDelete: Cascade)
  term         String
  type         KeywordType @default(KEYWORD)
  createdAt    DateTime    @default(now())

  @@unique([monitoringId, term, type])
  @@map("keywords")
}

enum KeywordType {
  KEYWORD
  HASHTAG
  COMPETITOR
  BRAND
}

// Fonte como String (não enum) para permitir novas fontes (INSTAGRAM, FACEBOOK,
// TIKTOK, X, THREADS, LINKEDIN…) sem migração. Valores atuais:
// GOOGLE_NEWS | REDDIT | YOUTUBE | RSS.
model ListeningSource {
  id              String     @id @default(cuid())
  monitoringId    String
  monitoring      Monitoring @relation(fields: [monitoringId], references: [id], onDelete: Cascade)
  type            String
  name            String?
  config          Json? // ex: { feedUrl } para RSS
  enabled         Boolean    @default(true)
  lastCollectedAt DateTime?
  createdAt       DateTime   @default(now())

  @@index([monitoringId])
  @@map("sources")
}

model Mention {
  id                String            @id @default(cuid())
  monitoringId      String
  monitoring        Monitoring        @relation(fields: [monitoringId], references: [id], onDelete: Cascade)
  sourceType        String // GOOGLE_NEWS | REDDIT | YOUTUBE | RSS | futuros
  urlHash           String // sha256(url) — deduplicação
  url               String
  title             String?
  text              String?
  summary           String?
  author            String?
  sourceName        String? // veículo/site/canal
  language          String?
  imageUrl          String?
  publishedAt       DateTime?
  collectedAt       DateTime          @default(now())
  matchedKeyword    String?
  matchedBrand      String?
  matchedCompetitor String?
  sentiment         MentionSentiment?
  createdAt         DateTime          @default(now())

  @@unique([monitoringId, urlHash])
  @@index([monitoringId, publishedAt])
  @@map("mentions")
}

model MentionSentiment {
  id             String         @id @default(cuid())
  mentionId      String         @unique
  mention        Mention        @relation(fields: [mentionId], references: [id], onDelete: Cascade)
  sentiment      SentimentLabel
  score          Float // -1 (muito negativo) a 1 (muito positivo)
  summary        String?
  category       String?
  theme          String?
  urgency        String? // baixa | media | alta
  intent         String?
  entities       Json? // ["Empresa X", "Produto Y"]
  suggestedReply String?
  analyzedAt     DateTime       @default(now())

  @@map("mention_sentiments")
}

enum SentimentLabel {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model ListeningAiReport {
  id           String     @id @default(cuid())
  monitoringId String
  monitoring   Monitoring @relation(fields: [monitoringId], references: [id], onDelete: Cascade)
  period       String // weekly | monthly
  periodKey    String // ex: "2026-W27" ou "2026-07"
  report       Json
  generatedAt  DateTime   @default(now())

  @@unique([monitoringId, period, periodKey])
  @@map("ai_analysis")
}

// Estrutura de alertas (sem notificações por enquanto — apenas arquitetura).
// type: NEGATIVE_SPIKE | VOLUME_SPIKE | CRITICAL_KEYWORD | CRISIS
model ListeningAlertRule {
  id           String     @id @default(cuid())
  monitoringId String
  monitoring   Monitoring @relation(fields: [monitoringId], references: [id], onDelete: Cascade)
  type         String
  config       Json? // ex: { threshold: 10, windowHours: 24, keywords: [...] }
  enabled      Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([monitoringId])
  @@map("listening_alert_rules")
}
